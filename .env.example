# SUNARP Vehicle Consultation API Configuration
# Copy this file to .env and adjust values as needed

# Run browser in headless mode (no visible window)
# Set to "true" for server/production environments
# Set to "false" for debugging or if captcha fails
# Docker Compose runs with Xvfb by default, so "false" is usually
# more reliable for Cloudflare/Turnstile challenges.
SUNARP_HEADLESS=false

# Use longer timeouts for slow internet connections
# Set to "true" if you have slow/unstable internet
SUNARP_SLOW_MODE=false

# API server host and port
SUNARP_HOST=0.0.0.0
SUNARP_PORT=8000

# Optional: host port exposed by Docker Compose
# Useful if local port 8000 is already in use.
SUNARP_PUBLIC_PORT=8000

# Optional: custom Chromium binary path
# Leave unset to auto-detect common paths.
# Useful in Docker: /usr/bin/chromium
# SUNARP_CHROMIUM_PATH=/usr/bin/chromium

# Optional: dynamic latency profile (fast mode)
# Defaults aim for quick fail (~10-15s) when there is no real progress.
SUNARP_TOTAL_BUDGET_SECONDS=18
SUNARP_GATE_INITIAL_SECONDS=8
SUNARP_GATE_RETRY_SECONDS=4
SUNARP_API_WAIT_SECONDS=6
SUNARP_NO_PROGRESS_FAIL_SECONDS=3.5
SUNARP_PROGRESS_EXTENSION_SECONDS=6
SUNARP_MAX_PROGRESS_EXTENSIONS=2
SUNARP_MAX_SUBMIT_ATTEMPTS=2
SUNARP_REQUIRE_TOKEN_ON_RETRY=true

# Optional: dynamic latency profile (slow mode)
# Used when SUNARP_SLOW_MODE=true or ?slow=true is passed to endpoints.
SUNARP_TOTAL_BUDGET_SLOW_SECONDS=75
SUNARP_GATE_INITIAL_SECONDS_SLOW=20
SUNARP_GATE_RETRY_SECONDS_SLOW=12
SUNARP_API_WAIT_SECONDS_SLOW=16
SUNARP_NO_PROGRESS_FAIL_SECONDS_SLOW=8
SUNARP_MAX_PROGRESS_EXTENSIONS_SLOW=4
SUNARP_MAX_SUBMIT_ATTEMPTS_SLOW=3
